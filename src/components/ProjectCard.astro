---
interface Project {
  slug: string;
  name: string;
  tagline: string;
  role: string;
  year: string;
  stack: string[];
  highlights: string[];
  url?: string;
  confidential?: boolean;
}
const { project } = Astro.props as { project: Project };
const hasLink = project.url && !project.url.startsWith("TODO") && project.url !== "private";
---

<article class="group rounded-2xl border border-[var(--color-line)] bg-white p-6 transition-shadow hover:shadow-[0_8px_30px_rgba(11,16,32,0.06)]">
  <div class="flex items-baseline justify-between gap-4">
    <h3 class="text-xl font-bold">{project.name}</h3>
    <span class="shrink-0 text-xs text-[var(--color-muted)]">{project.year}</span>
  </div>
  <p class="mt-1 text-sm font-medium text-[var(--color-accent)]">{project.role}</p>
  <p class="mt-3 text-[var(--color-body)]">{project.tagline}</p>

  <ul class="mt-4 space-y-1.5 text-sm text-[var(--color-body)]">
    {project.highlights.map((h) => (
      <li class="flex gap-2">
        <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-[var(--color-accent)]" />
        <span>{h}</span>
      </li>
    ))}
  </ul>

  <div class="mt-5 flex flex-wrap gap-2">
    {project.stack.map((s) => (
      <span class="rounded-full border border-[var(--color-line)] px-2.5 py-1 text-xs text-[var(--color-muted)]">{s}</span>
    ))}
  </div>

  {hasLink && (
    <a href={project.url} class="mt-5 inline-flex items-center gap-1 text-sm font-medium text-[var(--color-accent)] hover:text-[var(--color-accent-hover)]">
      Visit project
      <span aria-hidden>→</span>
    </a>
  )}
</article>
