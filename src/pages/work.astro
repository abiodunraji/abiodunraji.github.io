---
import Base from "../layouts/Base.astro";
import ProjectCard from "../components/ProjectCard.astro";
import projects from "../data/projects.json";
---

<Base title="Work" description="Selected projects — full-stack web, mobile, and AI products.">
  <section class="mx-auto max-w-5xl px-6 pt-20 pb-4">
    <h1 class="reveal text-4xl font-bold sm:text-5xl">Work</h1>
    <p class="reveal mt-4 max-w-2xl text-lg text-[var(--color-body)]" data-d="1">
      A selection of products I've built — from healthcare and fintech to AI and
      commercial sites. Each one shipped, not a sketch.
    </p>
  </section>

  <section class="mx-auto max-w-5xl px-6">
    <div class="grid gap-6 sm:grid-cols-2">
      {projects.map((project) => (
        <div class="reveal">
          <ProjectCard project={project} />
        </div>
      ))}
    </div>
  </section>
</Base>
